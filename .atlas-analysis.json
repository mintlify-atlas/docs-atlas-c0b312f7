  "keyFeatures": [
    "Strongly-typed key-value storage with explicit type and default value declarations",
    "SwiftUI @Default property wrapper for reactive view updates",
    "Defaults.Toggle SwiftUI component for Bool keys",
    "@ObservableDefault macro for use in @Observable classes",
    "Async/await observation via Defaults.updates() returning AsyncStream",
    "Combine publisher support via Defaults.publisher()",
    "iCloud sync via NSUbiquitousKeyValueStore with automatic conflict resolution",
    "Codable support for arbitrary value types",
    "NSSecureCoding support for legacy AppKit/UIKit types",
    "Custom bridge protocol for user-defined serialization",
    "Support for collections: Array, Set, Dictionary, Range, ClosedRange",
    "SwiftUI Color, NSColor/UIColor, UUID, URL, and font descriptors natively supported",
    "Custom suite (UserDefaults app groups) support",
    "Reset keys to default values individually or in bulk"
  ],
  "publicApiSurface": [
    "Defaults[key]",
    "Defaults.Key<Value>",
    "Defaults.Keys",
    "Defaults.Serializable",
    "Defaults.Bridge",
    "Defaults.PreferRawRepresentable",
    "Defaults.PreferNSSecureCoding",
    "Defaults.CollectionSerializable",
